# MongoDB connection string
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/Ishop?retryWrites=true&w=majority

# Server port (Render sets this automatically)
PORT=5000

# JWT secret
SECRET_KEY=your_secret_key_here

# Email credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS — set this in Render → Environment Variables
FRONTEND_URL=https://your-vercel-frontend-domain.vercel.app
