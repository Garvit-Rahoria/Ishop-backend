# MongoDB connection string
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/Ishop?retryWrites=true&w=majority

# Server port (Render sets this automatically)
PORT=5000

# JWT secret
SECRET_KEY=your_secret_key_here

# Email credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL here in Render → Environment Variables
# Example: https://ishop.vercel.app,http://localhost:3000
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://swoo-techmart-gilt.vercel.app,http://localhost:3000
